#!/usr/bin/env python3

import argparse
import csv
import os
import shutil
import subprocess
from pathlib import Path

from Bio import AlignIO

from phyluce.generic_align import GenericAlign


DATASET_CHOICES = ("complete", "incomplete")


def get_args():
    parser = argparse.ArgumentParser(
        description=(
            "Trim aligned per-locus FASTA files using edge trimming, internal "
            "Gblocks trimming, both strategies, or no trimming."
        )
    )
    parser.add_argument(
        "--input-dir",
        required=True,
        help="Stage 09 directory containing dataset subdirectories.",
    )
    parser.add_argument(
        "--output-dir",
        required=True,
        help="Directory for trimmed locus FASTA outputs.",
    )
    parser.add_argument(
        "--dataset-modes",
        default=None,
        help=(
            "Optional comma-separated dataset labels to trim. Accepts "
            "'complete' and/or 'incomplete'. "
            "Defaults to all datasets found in --input-dir."
        ),
    )
    parser.add_argument(
        "--trim-mode",
        choices=["edge", "internal", "both", "none"],
        default="edge",
        help="Trim strategy to apply.",
    )
    parser.add_argument("--window", type=int, default=20)
    parser.add_argument("--proportion", type=float, default=0.65)
    parser.add_argument("--threshold", type=float, default=0.65)
    parser.add_argument("--max-divergence", type=float, default=0.20)
    parser.add_argument("--min-length", type=int, default=100)
    parser.add_argument(
        "--gblocks-path",
        default="Gblocks",
        help="Path to the Gblocks executable for internal trimming.",
    )
    parser.add_argument("--gblocks-b1", type=float, default=0.5)
    parser.add_argument("--gblocks-b2", type=float, default=0.85)
    parser.add_argument("--gblocks-b3", type=int, default=8)
    parser.add_argument("--gblocks-b4", type=int, default=10)
    return parser.parse_args()


def parse_dataset_modes(text):
    if not text:
        return None
    labels = []
    seen = set()
    for item in text.split(","):
        value = item.strip()
        if not value:
            continue
        if value not in DATASET_CHOICES:
            raise RuntimeError(
                "Unsupported dataset mode: {}. Expected one of {}".format(
                    value, ", ".join(DATASET_CHOICES)
                )
            )
        if value not in seen:
            seen.add(value)
            labels.append(value)
    if not labels:
        raise RuntimeError("No valid dataset modes were provided.")
    return labels


def resolve_dataset_labels(input_dir, dataset_modes_text):
    requested = parse_dataset_modes(dataset_modes_text)
    if requested is not None:
        return requested
    input_root = Path(input_dir).resolve()
    labels = []
    for path in sorted(input_root.iterdir()):
        if path.is_dir() and (path / "alignments").is_dir():
            labels.append(path.name)
    if not labels:
        raise RuntimeError(
            "No dataset directories with alignments/ found under {}".format(input_root)
        )
    return labels


def discover_alignment_fastas(input_dir, dataset_label):
    alignments_dir = Path(input_dir).resolve() / dataset_label / "alignments"
    if not alignments_dir.is_dir():
        raise RuntimeError("Missing alignments directory: {}".format(alignments_dir))
    fasta_files = sorted(alignments_dir.glob("*.fasta"))
    if not fasta_files:
        raise RuntimeError("No aligned FASTA files found under {}".format(alignments_dir))
    return fasta_files


def alignment_taxa_and_length(path):
    aln = AlignIO.read(str(path), "fasta")
    return len(aln), aln.get_alignment_length()


def trim_one_alignment_edge(path, output_path, args):
    input_taxa, input_length = alignment_taxa_and_length(path)
    aln = GenericAlign(str(path))
    aln._read("fasta")
    aln.trim_alignment(
        method="running",
        window_size=args.window,
        proportion=args.proportion,
        threshold=args.threshold,
        max_divergence=args.max_divergence,
        min_len=args.min_length,
    )
    if aln.trimmed is None:
        return {
            "status": "dropped",
            "reason": "trim_failed_or_below_min_length",
            "input_taxa": input_taxa,
            "input_length": input_length,
            "output_taxa": 0,
            "output_length": 0,
        }
    output_path.parent.mkdir(parents=True, exist_ok=True)
    with open(output_path, "w") as handle:
        handle.write(aln.trimmed.format("fasta"))
    output_taxa = len(aln.trimmed)
    output_length = aln.trimmed.get_alignment_length()
    return {
        "status": "trimmed",
        "reason": "",
        "input_taxa": input_taxa,
        "input_length": input_length,
        "output_taxa": output_taxa,
        "output_length": output_length,
    }


def trim_one_alignment_none(path, output_path):
    input_taxa, input_length = alignment_taxa_and_length(path)
    output_path.parent.mkdir(parents=True, exist_ok=True)
    shutil.copyfile(path, output_path)
    return {
        "status": "copied",
        "reason": "",
        "input_taxa": input_taxa,
        "input_length": input_length,
        "output_taxa": input_taxa,
        "output_length": input_length,
    }


def trim_one_alignment_internal(path, output_path, args):
    input_taxa, input_length = alignment_taxa_and_length(path)
    b1 = int(round(args.gblocks_b1 * input_taxa)) + 1
    b2 = int(round(args.gblocks_b2 * input_taxa))
    if b2 < b1:
        b2 = b1
    command = [
        str(args.gblocks_path),
        str(path),
        "-t=DNA",
        "-b1={}".format(b1),
        "-b2={}".format(b2),
        "-b3={}".format(args.gblocks_b3),
        "-b4={}".format(args.gblocks_b4),
        "-b5=h",
        "-p=n",
    ]
    process = subprocess.run(
        command,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        universal_newlines=True,
        check=False,
    )
    if process.returncode != 0:
        return {
            "status": "dropped",
            "reason": "gblocks_failed",
            "input_taxa": input_taxa,
            "input_length": input_length,
            "output_taxa": 0,
            "output_length": 0,
        }
    trimmed_path = Path(str(path) + "-gb")
    if not trimmed_path.is_file():
        return {
            "status": "dropped",
            "reason": "gblocks_output_missing",
            "input_taxa": input_taxa,
            "input_length": input_length,
            "output_taxa": 0,
            "output_length": 0,
        }
    try:
        aln = AlignIO.read(str(trimmed_path), "fasta")
        output_path.parent.mkdir(parents=True, exist_ok=True)
        with open(output_path, "w") as handle:
            AlignIO.write(aln, handle, "fasta")
        output_taxa = len(aln)
        output_length = aln.get_alignment_length()
        if output_length < args.min_length:
            output_path.unlink(missing_ok=True)
            return {
                "status": "dropped",
                "reason": "below_min_length_after_gblocks",
                "input_taxa": input_taxa,
                "input_length": input_length,
                "output_taxa": 0,
                "output_length": 0,
            }
        return {
            "status": "trimmed",
            "reason": "",
            "input_taxa": input_taxa,
            "input_length": input_length,
            "output_taxa": output_taxa,
            "output_length": output_length,
        }
    finally:
        trimmed_path.unlink(missing_ok=True)
        Path(str(path) + "-gb.htm").unlink(missing_ok=True)


def trim_one_alignment(path, output_path, trim_mode, args):
    if trim_mode == "edge":
        return trim_one_alignment_edge(path, output_path, args)
    if trim_mode == "internal":
        return trim_one_alignment_internal(path, output_path, args)
    if trim_mode == "none":
        return trim_one_alignment_none(path, output_path)
    raise RuntimeError("Unsupported trim mode: {}".format(trim_mode))


def mode_output_dir(output_root, trim_mode, dataset_label, compatibility_mode):
    if compatibility_mode:
        return Path(output_root).resolve() / dataset_label
    return Path(output_root).resolve() / trim_mode / dataset_label


def trim_dataset(input_dir, output_root, dataset_label, trim_mode, args, compatibility_mode):
    fasta_files = discover_alignment_fastas(input_dir, dataset_label)
    dataset_output = mode_output_dir(output_root, trim_mode, dataset_label, compatibility_mode)
    trimmed_dir = dataset_output / "trimmed_alignments"
    summary_rows = []
    for fasta_path in fasta_files:
        output_path = trimmed_dir / fasta_path.name
        if output_path.exists():
            output_taxa, output_length = alignment_taxa_and_length(output_path)
            input_taxa, input_length = alignment_taxa_and_length(fasta_path)
            summary_rows.append(
                {
                    "trim_mode": trim_mode,
                    "dataset_label": dataset_label,
                    "uce_locus": fasta_path.stem,
                    "input_fasta": str(fasta_path),
                    "output_fasta": str(output_path),
                    "input_taxa": input_taxa,
                    "input_length": input_length,
                    "output_taxa": output_taxa,
                    "output_length": output_length,
                    "status": "existing",
                    "reason": "",
                }
            )
            continue
        result = trim_one_alignment(fasta_path, output_path, trim_mode, args)
        summary_rows.append(
            {
                "trim_mode": trim_mode,
                "dataset_label": dataset_label,
                "uce_locus": fasta_path.stem,
                "input_fasta": str(fasta_path),
                "output_fasta": str(output_path) if result["status"] != "dropped" else "",
                "input_taxa": result["input_taxa"],
                "input_length": result["input_length"],
                "output_taxa": result["output_taxa"],
                "output_length": result["output_length"],
                "status": result["status"],
                "reason": result["reason"],
            }
        )
    summary_rows.sort(key=lambda row: row["uce_locus"])
    return dataset_output, summary_rows


def write_summary(path, rows):
    fieldnames = [
        "trim_mode",
        "dataset_label",
        "uce_locus",
        "input_fasta",
        "output_fasta",
        "input_taxa",
        "input_length",
        "output_taxa",
        "output_length",
        "status",
        "reason",
    ]
    with open(path, "w", newline="") as handle:
        writer = csv.DictWriter(handle, fieldnames=fieldnames, delimiter="\t")
        writer.writeheader()
        for row in rows:
            writer.writerow(row)


def write_manifest(path, rows):
    fieldnames = [
        "trim_mode",
        "dataset_label",
        "trimmed_files",
        "existing_files",
        "copied_files",
        "dropped_files",
        "total_files",
        "output_dir",
        "summary_path",
    ]
    with open(path, "w", newline="") as handle:
        writer = csv.DictWriter(handle, fieldnames=fieldnames, delimiter="\t")
        writer.writeheader()
        for row in rows:
            writer.writerow(row)


def main():
    args = get_args()
    dataset_labels = resolve_dataset_labels(args.input_dir, args.dataset_modes)
    output_root = Path(args.output_dir).resolve()
    output_root.mkdir(parents=True, exist_ok=True)

    trim_modes = ["edge", "internal"] if args.trim_mode == "both" else [args.trim_mode]
    compatibility_mode = args.trim_mode in {"edge", "internal", "none"}

    all_rows = []
    manifest_rows = []
    for trim_mode in trim_modes:
        for dataset_label in dataset_labels:
            dataset_output, summary_rows = trim_dataset(
                args.input_dir,
                args.output_dir,
                dataset_label,
                trim_mode,
                args,
                compatibility_mode and len(trim_modes) == 1,
            )
            summary_path = dataset_output / "trimming_summary.tsv"
            write_summary(summary_path, summary_rows)
            all_rows.extend(summary_rows)
            manifest_rows.append(
                {
                    "trim_mode": trim_mode,
                    "dataset_label": dataset_label,
                    "trimmed_files": sum(1 for row in summary_rows if row["status"] == "trimmed"),
                    "existing_files": sum(1 for row in summary_rows if row["status"] == "existing"),
                    "copied_files": sum(1 for row in summary_rows if row["status"] == "copied"),
                    "dropped_files": sum(1 for row in summary_rows if row["status"] == "dropped"),
                    "total_files": len(summary_rows),
                    "output_dir": str(dataset_output),
                    "summary_path": str(summary_path),
                }
            )

    write_summary(output_root / "all_trimming_manifest.tsv", all_rows)
    write_manifest(output_root / "threshold_manifest.tsv", manifest_rows)
    print(
        "Trimmed locus alignments for {} datasets across {} trim mode(s) under {}".format(
            len(dataset_labels), len(trim_modes), output_root
        )
    )
    print("manifest\t{}".format(output_root / "threshold_manifest.tsv"))


if __name__ == "__main__":
    main()
