    )


def concurrency_from_threads(total_threads, per_job, override):
    if override is not None:
        return max(1, override)
    return max(1, total_threads // per_job)


def run_fastp_for_samples(samples, trimmed_root, fastp_path, total_threads, threads_per_job, max_jobs, logger, log_root):
    jobs = concurrency_from_threads(total_threads, threads_per_job, max_jobs)
    with concurrent.futures.ThreadPoolExecutor(max_workers=jobs) as executor:
        futures = [
            executor.submit(
                run_fastp,
                sample,
                raw_pair,
                trimmed_root,
                fastp_path,
                threads_per_job,
                logger,
                log_root,
            )
            for sample, raw_pair in samples.items()
        ]
        for future in concurrent.futures.as_completed(futures):
            future.result()


def fasta_lengths(fasta_path):
    lengths = []
    current = 0
    with open(fasta_path) as handle:
        for line in handle:
            line = line.strip()
            if not line:
                continue
            if line.startswith(">"):
                if current:
                    lengths.append(current)
                current = 0
            else:
                current += len(line)
    if current:
        lengths.append(current)
    return lengths


def nx_from_lengths(lengths, fraction):
    if not lengths:
        return 0
    target = sum(lengths) * fraction
    running = 0
    for length in sorted(lengths, reverse=True):
        running += length
        if running >= target:
            return length
    return 0


def summarize_contigs(sample, assembly_root):
    contigs = Path(assembly_root) / sample / "contigs.fasta"
    lengths = fasta_lengths(contigs)
    total_size = sum(lengths)
    return OrderedDict(
        [
            ("Sample", sample),
            ("Contigs path", str(contigs)),
            ("Total size", total_size),
            ("Number of contigs", len(lengths)),
            ("N50", nx_from_lengths(lengths, 0.5)),
            ("N90", nx_from_lengths(lengths, 0.9)),
            ("Longest contig", max(lengths) if lengths else 0),
        ]
    )


def write_contig_summary(sample, assembly_root):
    summary = summarize_contigs(sample, assembly_root)
    sample_dir = Path(assembly_root) / sample
    summary_path = sample_dir / "{}.contigs.summary.tsv".format(sample)
    with open(summary_path, "w") as handle:
        handle.write("\t".join(summary.keys()) + "\n")
        handle.write("\t".join(str(value) for value in summary.values()) + "\n")
    return summary


def write_spades_summary_table(samples, assembly_root, logger):
    summaries = [write_contig_summary(sample, assembly_root) for sample in samples]
    if not summaries:
        return
    summary_path = Path(assembly_root) / "assembly_summary.tsv"
    with open(summary_path, "w") as handle:
        handle.write("\t".join(summaries[0].keys()) + "\n")
        for summary in summaries:
            handle.write("\t".join(str(value) for value in summary.values()) + "\n")
    logger.info("Wrote SPAdes assembly summary: {}".format(summary_path))


