def main():
    args = get_args()
    args.start_stage, args.end_stage = determine_stage_range(args)
    if args.start_stage > args.end_stage:
        raise RuntimeError("--start-stage cannot be greater than --end-stage.")
    selected_stages = set(range(args.start_stage, args.end_stage + 1))
    need_raw_samples = bool(selected_stages & {1, 2})
    need_assembly_samples = bool(selected_stages & {3, 4, 5, 6})
    current_dir = Path(os.getcwd()).resolve()
    raw_dir = resolve_raw_dir(current_dir, args.raw_dir) if need_raw_samples else None
    project_id, project_dir = resolve_project_path(current_dir, args.project_id, raw_dir=raw_dir)
    project_info = read_project_info(project_dir) or {}
    settings = resolve_pipeline_settings(args, project_info, selected_stages, current_dir)

    fastp_path = require_executable(["fastp"]) if 1 in selected_stages else None
    spades_path = require_executable(["spades.py"]) if 2 in selected_stages else None
    minimap2_path = require_executable(["minimap2"]) if 3 in selected_stages else None
    mafft_path = None
    if 9 in selected_stages:
        mafft_path = (
            str(Path(settings["mafft_path"]).expanduser())
            if settings["mafft_path"] and settings["mafft_path"] != "mafft"
            else require_executable(["mafft"])
        )
    decompressor = shutil.which("pigz") or shutil.which("gzip")
    if raw_dir is not None and 1 in selected_stages and decompressor is None and any(
        path.name.lower().endswith(GZ_FASTQ_EXTENSIONS)
        for path in raw_dir.iterdir()
        if path.is_file()
    ):
        raise RuntimeError("Found .gz FASTQ files but neither pigz nor gzip is available.")

    script_dir = Path(__file__).resolve().parent
    prepare_script = script_dir / "phyluce_assembly_prepare_uce_hits_from_paf"
    filter_script = script_dir / "phyluce_assembly_filter_uce_hits_trace"
    extract_script = script_dir / "phyluce_assembly_extract_uce_fasta_from_hits"
    aggregate_script = script_dir / "phyluce_assembly_aggregate_filtered_loci"
    export_locus_fastas_script = script_dir / "phyluce_assembly_export_locus_fastas"
    align_locus_fastas_script = script_dir / "phyluce_assembly_align_locus_fastas"
    trim_locus_alignments_script = script_dir / "phyluce_assembly_trim_locus_alignments"
    filter_locus_alignments_script = script_dir / "phyluce_assembly_filter_locus_alignments_by_taxa"
    add_missing_data_script = script_dir / "phyluce_assembly_add_missing_taxa_designators"
    concatenate_alignments_script = script_dir / "phyluce_assembly_concatenate_locus_alignments"

    probes_path = settings["probes"]
    if need_raw_samples:
        samples = find_raw_fastq_pairs(raw_dir)
    elif need_assembly_samples:
        assembly_root = project_dir / "02_Spades_assembly"
        samples = find_samples_from_assembly(assembly_root, strict=not args.dry_run)
    else:
        samples = {}
    executables = {
        "fastp": fastp_path,
        "spades": spades_path,
        "minimap2": minimap2_path,
        "prepare": prepare_script,
        "filter": filter_script,
        "extract": extract_script,
