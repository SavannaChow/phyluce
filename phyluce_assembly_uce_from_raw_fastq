            logger,
            stage_dirs["00_Log"],
        )
    if args.start_stage <= 10 <= args.end_stage:
        run_trim_locus_alignments(
            trim_locus_alignments_script,
            stage_dirs["09_Aligned_Locus_FASTAs"],
