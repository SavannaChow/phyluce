            add_missing_data_script,
            stage_dirs["11_Filtered_Locus_ALIGNMENTS"],
            stage_dirs["07_Aggregated_loci"] / "{}.filtered.loci.tsv".format(project_id),
            stage_dirs["12_Missing_Data_Designators"],
            settings["align_thresholds"],
            settings["post_align_thresholds"],
