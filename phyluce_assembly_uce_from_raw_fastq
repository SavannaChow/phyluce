def decompress_fastqs(workdir, threads, decompressor, logger, log_root):
    workdir = Path(workdir)
    for path in sorted(workdir.iterdir()):
        if not path.is_file():
            continue
        lower = path.name.lower()
        if not lower.endswith(GZ_FASTQ_EXTENSIONS):
            continue
        target = path.with_suffix("")
        if target.exists():
            continue
        if "pigz" in os.path.basename(decompressor):
            command = [decompressor, "-d", "-k", "-p", str(threads), str(path)]
        else:
            command = [decompressor, "-d", "-k", str(path)]
        stream_process(
            command,
            logger,
            log_path=log_root / "decompress.{}.log".format(path.name),
        )


def find_raw_fastq_pairs(workdir):
    pairs = {}
    raw_fastq_files = []
    invalid_names = []
    workdir = Path(workdir)
    for path in sorted(workdir.iterdir()):
        if not path.is_file():
            continue
        lower = path.name.lower()
        if not lower.endswith(FASTQ_EXTENSIONS):
            continue
        raw_fastq_files.append(path)
        match = FASTQ_PATTERN.match(path.name)
        if not match:
            invalid_names.append(path.name)
            continue
        sample = match.group("sample")
        read = match.group("read")
        pairs.setdefault(sample, {})
        if read in pairs[sample]:
            raise RuntimeError(
                "Duplicate FASTQ detected for sample {} read R{}.".format(sample, read)
            )
        pairs[sample][read] = path
    if invalid_names:
        raise RuntimeError(
            "Found FASTQ files that do not match the required pattern "
            "'sampleID_species_R1/2.fastq' or '.fq':\n{}".format(
                "\n".join("  {}".format(name) for name in invalid_names)
            )
        )
    missing = [sample for sample, reads in pairs.items() if set(reads) != {"1", "2"}]
    if missing:
        raise RuntimeError(
            "Missing R1/R2 mate for samples: {}".format(", ".join(sorted(missing)))
        )
    if not raw_fastq_files:
        raise RuntimeError("No FASTQ pairs found in {}".format(workdir))
    matched_count = sum(len(reads) for reads in pairs.values())
    if matched_count != len(raw_fastq_files):
        raise RuntimeError(
            "FASTQ validation failed: found {} FASTQ files, but only {} matched the "
            "required naming rule.".format(len(raw_fastq_files), matched_count)
        )
    return {sample: (reads["1"], reads["2"]) for sample, reads in sorted(pairs.items())}


def find_samples_from_assembly(assembly_root, strict=True):
    assembly_root = Path(assembly_root)
    if not assembly_root.is_dir():
        if strict:
            raise RuntimeError("Assembly directory not found: {}".format(assembly_root))
        return {}
    samples = {}
    for sample_dir in sorted(assembly_root.iterdir()):
        if not sample_dir.is_dir() or sample_dir.name.startswith("."):
            continue
        contigs = sample_dir / "contigs.fasta"
        if contigs.is_file():
            samples[sample_dir.name] = None
    if not samples and strict:
        raise RuntimeError(
            "No sample contigs found under {} (expect <sample>/contigs.fasta).".format(
                assembly_root
            )
        )
    return samples


def choose_probe_fasta(workdir, probes_arg):
    if probes_arg:
        path = Path(probes_arg).expanduser().resolve()
        if not path.is_file():
            raise RuntimeError("Probe FASTA not found: {}".format(path))
        return path

    candidates = [
        path
        for path in sorted(Path(workdir).iterdir())
        if path.is_file() and path.suffix.lower() in FASTA_EXTENSIONS
    ]
    if not candidates:
        raise RuntimeError(
            "No probe FASTA found in the first level of {}".format(workdir)
        )
    if len(candidates) == 1:
        return candidates[0]
    if not sys.stdin.isatty():
        raise RuntimeError(
            "Multiple FASTA files found in {}. Re-run with --probes.\n{}".format(
                workdir,
                "\n".join("  {}. {}".format(idx + 1, path.name) for idx, path in enumerate(candidates)),
            )
        )
    print("Multiple FASTA files found. Choose the probe FASTA:")
    for idx, path in enumerate(candidates, start=1):
        print("  {}. {}".format(idx, path.name))
    while True:
        answer = input("Enter choice number: ").strip()
        if answer.isdigit():
            choice = int(answer)
            if 1 <= choice <= len(candidates):
                return candidates[choice - 1]
        print("Invalid choice.")


