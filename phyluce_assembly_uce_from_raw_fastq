            "max_spades_jobs": settings["max_spades_jobs"],
            "spades_memory_gb": settings["spades_memory_gb"],
            "spades_cov_cutoff": settings["spades_cov_cutoff"],
            "min_identity": settings["min_identity"],
            "min_coverage": settings["min_coverage"],
            "extract_mode": settings["extract_mode"],
            "flank": settings["flank"],
            "locus_thresholds": settings["locus_thresholds"],
            "align_thresholds": settings["align_thresholds"],
            "align_ambiguous": settings["align_ambiguous"],
            "align_matrix_mode": settings["align_matrix_mode"],
            "mafft_path": mafft_path or settings["mafft_path"],
            "trim_window": settings["trim_window"],
            "trim_proportion": settings["trim_proportion"],
            "trim_threshold": settings["trim_threshold"],
            "trim_max_divergence": settings["trim_max_divergence"],
            "trim_min_length": settings["trim_min_length"],
            "post_align_thresholds": settings["post_align_thresholds"],
            "missing_character": settings["missing_character"],
            "dry_run": args.dry_run,
            "start_stage": args.start_stage,
            "end_stage": args.end_stage,
            "fastp_path": fastp_path or "N/A",
            "spades_path": spades_path or "N/A",
            "minimap2_path": minimap2_path or "N/A",
            "mafft_path": mafft_path or "N/A",
            "decompressor": decompressor or "none",
            "raw_dir_source": args.raw_dir or "interactive_selection",
            "project_id_source": args.project_id or "interactive_input",
            "probes_source": args.probes or "auto_or_interactive_selection",
        }
    )
    logger.info("Project directory: {}".format(project_dir))
    if raw_dir is not None:
        logger.info("Raw FASTQ directory: {}".format(raw_dir))
    if probes_path is not None:
        logger.info("Probe FASTA: {}".format(probes_path))
    if raw_dir is not None and 1 in selected_stages and decompressor:
        decompress_fastqs(raw_dir, settings["threads"], decompressor, logger, stage_dirs["00_Log"])
    if samples:
        logger.info("Detected {} samples: {}".format(len(samples), ", ".join(samples)))
    else:
        logger.info("No sample scan required for selected stages.")

    if args.start_stage <= 1 <= args.end_stage:
        run_fastp_for_samples(
            samples,
            stage_dirs["01_Trimmed"],
