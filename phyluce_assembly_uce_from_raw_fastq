                ("min_identity", settings["min_identity"]),
                ("min_coverage", settings["min_coverage"]),
                ("extract_mode", settings["extract_mode"]),
                ("flank", settings["flank"]),
                ("locus_thresholds", settings["locus_thresholds"]),
                ("align_thresholds", settings["align_thresholds"]),
                ("align_ambiguous", settings["align_ambiguous"]),
                ("align_matrix_mode", settings["align_matrix_mode"]),
                ("mafft_path", mafft_path or settings["mafft_path"]),
                ("trim_window", settings["trim_window"]),
                ("trim_proportion", settings["trim_proportion"]),
                ("trim_threshold", settings["trim_threshold"]),
                ("trim_max_divergence", settings["trim_max_divergence"]),
                ("trim_min_length", settings["trim_min_length"]),
                ("post_align_thresholds", settings["post_align_thresholds"]),
                ("missing_character", settings["missing_character"]),
            ]
        ),
    )
    logger.save_run_config(
        {
            "project_id": project_id,
            "project_dir": project_dir,
            "raw_dir": raw_dir or "N/A",
            "probes": probes_path or "N/A",
            "threads": settings["threads"],
            "fastp_threads_per_job": settings["fastp_threads_per_job"],
            "max_fastp_jobs": settings["max_fastp_jobs"],
