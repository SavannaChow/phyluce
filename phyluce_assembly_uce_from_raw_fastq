    project_id, project_dir = resolve_project_for_run(current_dir, project_id, args.start_stage, raw_dir=raw_dir)
    stage_dirs = ensure_stage_dirs(project_dir)
    logger = PipelineLogger(stage_dirs["00_Log"])
    existing_project_info = read_project_info(project_dir) or {}
