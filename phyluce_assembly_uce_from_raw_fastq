            stage_dirs["12_Missing_Data_Designators"],
            stage_dirs["13_Concatenated_SUPERMATRICES"],
            settings["align_thresholds"],
            settings["post_align_thresholds"],
            logger,
            stage_dirs["00_Log"],
        )

    logger.info("Pipeline complete for {} samples.".format(len(samples)))
    logger.info("Logs: {}".format(stage_dirs["00_Log"]))


