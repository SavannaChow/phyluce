#!/usr/bin/env python3

import argparse
import csv
import shutil
from collections import OrderedDict
from pathlib import Path


DATASET_CHOICES = ("complete", "incomplete")
BRANCH_CHOICES = ("supermatrix", "gene-tree")


def get_args():
    parser = argparse.ArgumentParser(
        description=(
            "Dispatch finalized Stage 11 locus alignments into supermatrix and/or "
            "gene-tree analysis branches."
        )
    )
    parser.add_argument("--input-dir", required=True, help="Stage 11 directory.")
    parser.add_argument(
        "--aggregated-loci",
        required=True,
        help="Stage 07 aggregated long-format loci table used to recover all sample IDs.",
    )
    parser.add_argument("--output-dir", required=True, help="Directory for Stage 12 analysis branches.")
    parser.add_argument(
        "--threshold-groups",
        default=None,
        help=(
            "Optional dataset modes or threshold-group labels to process. Accepts "
            "'complete', 'incomplete', 'all', or specific Stage 11 threshold_group labels."
        ),
    )
    parser.add_argument(
        "--filter-labels",
        default=None,
        help=(
            "Optional comma-separated filter labels or values to process, e.g. "
            "'complete_matrix,min_taxa_075' or '1.0,0.75'. Defaults to all."
        ),
    )
    parser.add_argument(
        "--analysis-branches",
        default="both",
        help="Analysis branches to produce: 'supermatrix', 'gene-tree', or 'both'.",
    )
    parser.add_argument(
        "--missing-character",
        default="?",
        help="Character to use for missing data designators in the supermatrix branch.",
    )
    return parser.parse_args()


def parse_fasta(path):
    records = OrderedDict()
    current = None
    chunks = []
    with open(path) as handle:
        for raw in handle:
            line = raw.strip()
            if not line:
                continue
            if line.startswith(">"):
                if current is not None:
                    records[current] = "".join(chunks)
                current = line[1:].split()[0]
                chunks = []
            else:
                chunks.append(line)
    if current is not None:
        records[current] = "".join(chunks)
    return records


def write_fasta(path, records):
    with open(path, "w") as handle:
        for header, seq in records.items():
            handle.write(">{}\n".format(header))
            handle.write("{}\n".format(seq))


def normalize_taxon_name(name):
    while name.startswith("_R_"):
        name = name[3:]
    return name


def parse_analysis_branches(text):
    value = (text or "both").strip().lower()
    if value == "both":
        return list(BRANCH_CHOICES)
    branches = []
    seen = set()
    for item in value.split(","):
        branch = item.strip().lower()
        if not branch:
            continue
        if branch not in BRANCH_CHOICES:
            raise RuntimeError(
                "Unsupported analysis branch: {}. Expected one of {}".format(
                    branch, ", ".join(BRANCH_CHOICES + ("both",))
                )
            )
        if branch not in seen:
            seen.add(branch)
            branches.append(branch)
    if not branches:
        raise RuntimeError("No valid analysis branches were provided.")
    return branches


def read_all_taxa(aggregated_loci):
    taxa = []
    seen = set()
    with open(aggregated_loci, newline="") as handle:
        reader = csv.DictReader(handle, delimiter="\t")
        if reader.fieldnames is None or "sample_id" not in reader.fieldnames:
            raise RuntimeError("Unexpected aggregated loci schema in {}".format(aggregated_loci))
        for row in reader:
            sample_id = row["sample_id"].strip()
            if sample_id and sample_id not in seen:
                seen.add(sample_id)
                taxa.append(sample_id)
    if not taxa:
        raise RuntimeError("No sample_id values found in {}".format(aggregated_loci))
    return sorted(taxa)


def filter_label_from_value(value):
    threshold = float(value)
    if threshold <= 0 or threshold > 1:
        raise RuntimeError("Filter label values must be > 0 and <= 1: {}".format(value))
    if abs(threshold - 1.0) < 1e-9:
        return "complete_matrix"
    return "min_taxa_{:03d}".format(int(round(threshold * 100)))


def parse_filter_labels(requested):
    if not requested or str(requested).strip().lower() == "all":
        return None
    labels = []
    seen = set()
    for item in requested.split(","):
        value = item.strip()
        if not value:
            continue
        label = value if value == "complete_matrix" or value.startswith("min_taxa_") else filter_label_from_value(value)
        if label not in seen:
            seen.add(label)
            labels.append(label)
    if not labels:
        raise RuntimeError("No valid filter labels were provided.")
    return labels


def parse_threshold_groups(requested):
    if not requested or str(requested).strip().lower() == "all":
        return None, None
    dataset_modes = []
    dataset_seen = set()
    threshold_groups = []
    group_seen = set()
    for item in requested.split(","):
        value = item.strip()
        if not value:
            continue
        if value in DATASET_CHOICES:
            if value not in dataset_seen:
                dataset_seen.add(value)
                dataset_modes.append(value)
        else:
            if value not in group_seen:
                group_seen.add(value)
                threshold_groups.append(value)
    if not dataset_modes and not threshold_groups:
        raise RuntimeError("No valid threshold groups were provided.")
    return dataset_modes or None, threshold_groups or None


def read_stage11_manifest(input_dir):
    manifest_path = Path(input_dir).resolve() / "threshold_manifest.tsv"
    if not manifest_path.is_file():
        raise RuntimeError("Missing Stage 11 manifest: {}".format(manifest_path))
    rows = []
    with open(manifest_path, newline="") as handle:
        reader = csv.DictReader(handle, delimiter="\t")
        required = {
            "trim_mode",
            "dataset_label",
            "threshold_group",
            "completeness_threshold",
            "filter_label",
            "output_dir",
        }
        if reader.fieldnames is None or not required.issubset(set(reader.fieldnames)):
            raise RuntimeError("Unexpected Stage 11 manifest schema in {}".format(manifest_path))
        for row in reader:
            rows.append(
                {
                    "trim_mode": row["trim_mode"].strip(),
                    "dataset_label": row["dataset_label"].strip(),
                    "threshold_group": row["threshold_group"].strip(),
                    "completeness_threshold": row["completeness_threshold"].strip(),
                    "filter_label": row["filter_label"].strip(),
                    "output_dir": row["output_dir"].strip(),
                }
            )
    if not rows:
        raise RuntimeError("No rows found in {}".format(manifest_path))
    return rows


def select_stage11_rows(rows, requested_datasets, requested_threshold_groups, requested_filter_labels):
    selected = []
    seen = set()
    for row in rows:
        if requested_datasets is not None and row["dataset_label"] not in requested_datasets:
            if requested_threshold_groups is None or row["threshold_group"] not in requested_threshold_groups:
                continue
        elif requested_threshold_groups is not None and row["threshold_group"] not in requested_threshold_groups and row["dataset_label"] not in requested_threshold_groups:
            continue
        if requested_filter_labels is not None and row["filter_label"] not in requested_filter_labels:
            continue
        key = (
            row["trim_mode"],
            row["dataset_label"],
            row["threshold_group"],
            row["filter_label"],
            row["output_dir"],
        )
        if key in seen:
            continue
        seen.add(key)
        selected.append(row)
    if not selected:
        raise RuntimeError("No Stage 11 result combinations matched the requested filters.")
    return selected


def discover_alignments(combo_output_dir):
    alignments_dir = Path(combo_output_dir).resolve() / "alignments"
    if not alignments_dir.is_dir():
        raise RuntimeError("Missing alignments directory: {}".format(alignments_dir))
    files = sorted(alignments_dir.glob("*.fasta"))
    if not files:
        raise RuntimeError("No alignment FASTA files found under {}".format(alignments_dir))
    return files


def complete_alignment(fasta_path, output_path, all_taxa, missing_character):
    records = parse_fasta(fasta_path)
    normalized = OrderedDict()
    for header, seq in records.items():
        norm = normalize_taxon_name(header)
        if norm in normalized:
            raise RuntimeError(
                "Duplicate normalized taxon name {} in {}".format(norm, fasta_path)
            )
        normalized[norm] = seq
    lengths = {len(seq) for seq in normalized.values()}
    if len(lengths) != 1:
        raise RuntimeError("Alignment has inconsistent sequence lengths: {}".format(fasta_path))
    alignment_length = next(iter(lengths)) if lengths else 0
    missing_seq = missing_character * alignment_length
    completed = OrderedDict()
    added = []
    for taxon in all_taxa:
        if taxon in normalized:
            completed[taxon] = normalized[taxon]
        else:
            completed[taxon] = missing_seq
            added.append(taxon)
    output_path.parent.mkdir(parents=True, exist_ok=True)
    write_fasta(output_path, completed)
    return {
        "input_taxa": len(normalized),
        "output_taxa": len(completed),
        "alignment_length": alignment_length,
        "added_taxa_count": len(added),
        "added_taxa_ids": ",".join(added),
    }


def branch_combo_root(output_root, branch, row):
    return (
        Path(output_root).resolve()
        / branch
        / row["trim_mode"]
        / row["dataset_label"]
        / row["filter_label"]
    )


def build_base_row(row, branch, fasta_path, output_path):
    return {
        "analysis_branch": branch,
        "trim_mode": row["trim_mode"],
        "dataset_label": row["dataset_label"],
        "threshold_group": row["threshold_group"],
        "completeness_threshold": row["completeness_threshold"],
        "filter_label": row["filter_label"],
        "uce_locus": fasta_path.stem,
        "input_fasta": str(fasta_path),
        "output_fasta": str(output_path),
    }


def process_supermatrix_branch(row, fasta_files, output_root, all_taxa, missing_character):
    combo_root = branch_combo_root(output_root, "supermatrix", row)
    out_alignments = combo_root / "alignments"
    summary_rows = []
    files_with_added = 0
    for fasta_path in fasta_files:
        output_path = out_alignments / fasta_path.name
        result = complete_alignment(fasta_path, output_path, all_taxa, missing_character)
        if result["added_taxa_count"] > 0:
            files_with_added += 1
        summary_row = build_base_row(row, "supermatrix", fasta_path, output_path)
        summary_row.update(result)
        summary_rows.append(summary_row)
    summary_path = combo_root / "branch_summary.tsv"
    write_branch_summary(summary_path, summary_rows)
    manifest_row = {
        "analysis_branch": "supermatrix",
        "trim_mode": row["trim_mode"],
        "dataset_label": row["dataset_label"],
        "threshold_group": row["threshold_group"],
        "completeness_threshold": row["completeness_threshold"],
        "filter_label": row["filter_label"],
        "total_files": len(summary_rows),
        "files_with_added_taxa": files_with_added,
        "all_taxa_count": len(all_taxa),
        "output_dir": str(combo_root),
        "summary_path": str(summary_path),
    }
    return manifest_row, summary_rows


def process_gene_tree_branch(row, fasta_files, output_root):
    combo_root = branch_combo_root(output_root, "gene-tree", row)
    out_alignments = combo_root / "alignments"
    out_alignments.mkdir(parents=True, exist_ok=True)
    summary_rows = []
    for fasta_path in fasta_files:
        output_path = out_alignments / fasta_path.name
        shutil.copyfile(fasta_path, output_path)
        records = parse_fasta(fasta_path)
        lengths = {len(seq) for seq in records.values()}
        alignment_length = next(iter(lengths)) if lengths else 0
        summary_row = build_base_row(row, "gene-tree", fasta_path, output_path)
        summary_row.update(
            {
                "input_taxa": len(records),
                "output_taxa": len(records),
                "alignment_length": alignment_length,
                "added_taxa_count": 0,
                "added_taxa_ids": "",
            }
        )
        summary_rows.append(summary_row)
    summary_path = combo_root / "branch_summary.tsv"
    write_branch_summary(summary_path, summary_rows)
    manifest_row = {
        "analysis_branch": "gene-tree",
        "trim_mode": row["trim_mode"],
        "dataset_label": row["dataset_label"],
        "threshold_group": row["threshold_group"],
        "completeness_threshold": row["completeness_threshold"],
        "filter_label": row["filter_label"],
        "total_files": len(summary_rows),
        "files_with_added_taxa": 0,
        "all_taxa_count": "",
        "output_dir": str(combo_root),
        "summary_path": str(summary_path),
    }
    return manifest_row, summary_rows


def write_branch_summary(path, rows):
    fieldnames = [
        "analysis_branch",
        "trim_mode",
        "dataset_label",
        "threshold_group",
        "completeness_threshold",
        "filter_label",
        "uce_locus",
        "input_fasta",
        "output_fasta",
        "input_taxa",
        "output_taxa",
        "alignment_length",
        "added_taxa_count",
        "added_taxa_ids",
    ]
    with open(path, "w", newline="") as handle:
        writer = csv.DictWriter(handle, fieldnames=fieldnames, delimiter="\t")
        writer.writeheader()
        for row in rows:
            writer.writerow(row)


def write_manifest(path, rows):
    fieldnames = [
        "analysis_branch",
        "trim_mode",
        "dataset_label",
        "threshold_group",
        "completeness_threshold",
        "filter_label",
        "total_files",
        "files_with_added_taxa",
        "all_taxa_count",
        "output_dir",
        "summary_path",
    ]
    with open(path, "w", newline="") as handle:
        writer = csv.DictWriter(handle, fieldnames=fieldnames, delimiter="\t")
        writer.writeheader()
        for row in rows:
            writer.writerow(row)


def main():
    args = get_args()
    branches = parse_analysis_branches(args.analysis_branches)
    requested_datasets, requested_threshold_groups = parse_threshold_groups(args.threshold_groups)
    requested_filter_labels = parse_filter_labels(args.filter_labels)
    stage11_rows = read_stage11_manifest(args.input_dir)
    selected_rows = select_stage11_rows(
        stage11_rows,
        requested_datasets,
        requested_threshold_groups,
        requested_filter_labels,
    )
    all_taxa = read_all_taxa(args.aggregated_loci)
    output_root = Path(args.output_dir).resolve()
    output_root.mkdir(parents=True, exist_ok=True)

    manifest_rows = []
    all_rows = []
    for row in selected_rows:
        fasta_files = discover_alignments(row["output_dir"])
        for branch in branches:
            print(
                "[stage12:{}] {} / {} / {} ({})".format(
                    branch,
                    row["trim_mode"],
                    row["dataset_label"],
                    row["filter_label"],
                    len(fasta_files),
                ),
                flush=True,
            )
            if branch == "supermatrix":
                manifest_row, summary_rows = process_supermatrix_branch(
                    row, fasta_files, output_root, all_taxa, args.missing_character
                )
            else:
                manifest_row, summary_rows = process_gene_tree_branch(
                    row, fasta_files, output_root
                )
            manifest_rows.append(manifest_row)
            all_rows.extend(summary_rows)

    write_manifest(output_root / "branch_manifest.tsv", manifest_rows)
    write_branch_summary(output_root / "all_branch_locus_manifest.tsv", all_rows)
    print(
        "Prepared {} Stage 12 branch combinations under {}".format(
            len(manifest_rows), output_root
        )
    )
    print("manifest\t{}".format(output_root / "branch_manifest.tsv"))


if __name__ == "__main__":
    main()
