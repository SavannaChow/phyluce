#!/usr/bin/env python3

import argparse
import csv
import math
import shutil
from pathlib import Path

from Bio import AlignIO


def get_args():
    parser = argparse.ArgumentParser(
        description=(
            "Filter trimmed locus alignments by taxon completeness using the "
            "same core rule as phyluce_align_get_only_loci_with_min_taxa."
        )
    )
    parser.add_argument(
        "--input-dir",
        required=True,
        help="Stage 10 directory containing threshold subdirectories.",
    )
    parser.add_argument(
        "--reference-dir",
        required=True,
        help="Stage 09 directory used to recover the total expected taxa per threshold.",
    )
    parser.add_argument(
        "--output-dir",
        required=True,
        help="Directory for filtered locus alignments.",
    )
    parser.add_argument(
        "--threshold-groups",
        default=None,
        help=(
            "Optional comma-separated input threshold groups to process, e.g. "
            "'complete_matrix,coverage_090'. Defaults to all groups found in "
            "--input-dir."
        ),
    )
    parser.add_argument(
        "--completeness-thresholds",
        default="1.0",
        help=(
            "Comma-separated post-alignment completeness thresholds, e.g. "
            "'1.0,0.9,0.75'."
        ),
    )
    return parser.parse_args()


def parse_thresholds(text):
    thresholds = []
    seen = set()
    for item in text.split(","):
        value = item.strip()
        if not value:
            continue
        threshold = float(value)
        if threshold <= 0 or threshold > 1:
            raise RuntimeError(
                "Completeness thresholds must be > 0 and <= 1. Invalid value: {}".format(
                    value
                )
            )
        key = round(threshold, 6)
        if key not in seen:
            seen.add(key)
            thresholds.append(threshold)
    if not thresholds:
        raise RuntimeError("No valid completeness thresholds were provided.")
    return sorted(thresholds, reverse=True)


def threshold_group_labels(input_dir, thresholds_text):
    input_root = Path(input_dir).resolve()
    if thresholds_text:
        labels = [item.strip() for item in thresholds_text.split(",") if item.strip()]
        if not labels:
            raise RuntimeError("No valid threshold groups were provided.")
        return labels
    labels = []
    for path in sorted(input_root.iterdir()):
        if path.is_dir() and (path / "trimmed_alignments").is_dir():
            labels.append(path.name)
    if not labels:
        raise RuntimeError(
            "No threshold directories with trimmed_alignments/ found under {}".format(
                input_root
            )
        )
    return labels


def completeness_label(threshold):
    if abs(threshold - 1.0) < 1e-9:
        return "complete_matrix"
    return "min_taxa_{:03d}".format(int(round(threshold * 100)))


def read_total_taxa(reference_dir, threshold_group):
    summary_path = (
        Path(reference_dir).resolve() / threshold_group / "alignment_summary.tsv"
    )
    if not summary_path.is_file():
        raise RuntimeError(
            "Missing stage 09 alignment summary for {}: {}".format(
                threshold_group, summary_path
            )
        )
    total_taxa = None
    with open(summary_path, newline="") as handle:
        reader = csv.DictReader(handle, delimiter="\t")
        for row in reader:
            value = int(row["total_taxa"])
            if total_taxa is None:
                total_taxa = value
            elif total_taxa != value:
                raise RuntimeError(
                    "Inconsistent total_taxa values in {}".format(summary_path)
                )
    if total_taxa is None:
        raise RuntimeError("No rows found in {}".format(summary_path))
    return total_taxa


def discover_trimmed_alignments(input_dir, threshold_group):
    alignments_dir = Path(input_dir).resolve() / threshold_group / "trimmed_alignments"
    if not alignments_dir.is_dir():
        raise RuntimeError("Missing trimmed_alignments directory: {}".format(alignments_dir))
    files = sorted(alignments_dir.glob("*.fasta"))
    if not files:
        raise RuntimeError("No trimmed alignment FASTA files found under {}".format(alignments_dir))
    return files


def alignment_taxa(path):
    aln = AlignIO.read(str(path), "fasta")
    return len(aln)


def copy_alignments_for_threshold(input_dir, reference_dir, output_dir, threshold_group, completeness_threshold):
    total_taxa = read_total_taxa(reference_dir, threshold_group)
    min_count = int(math.floor(completeness_threshold * total_taxa))
    if min_count < 1:
        min_count = 1
    files = discover_trimmed_alignments(input_dir, threshold_group)
    filter_label = completeness_label(completeness_threshold)
    combo_root = Path(output_dir).resolve() / threshold_group / filter_label
    out_alignments = combo_root / "alignments"
    out_alignments.mkdir(parents=True, exist_ok=True)
    summary_rows = []
    kept = 0
    for path in files:
        taxa_count = alignment_taxa(path)
        keep = taxa_count >= min_count
        output_path = out_alignments / path.name if keep else None
        if keep:
            shutil.copyfile(path, output_path)
            kept += 1
        summary_rows.append(
            {
                "threshold_group": threshold_group,
                "completeness_threshold": "{:.4f}".format(completeness_threshold),
                "filter_label": filter_label,
                "uce_locus": path.stem,
                "input_fasta": str(path),
                "output_fasta": str(output_path) if keep else "",
                "total_taxa": total_taxa,
                "min_taxa_required": min_count,
                "alignment_taxa": taxa_count,
                "status": "kept" if keep else "dropped",
            }
        )
    summary_path = combo_root / "filter_summary.tsv"
    write_filter_summary(summary_path, summary_rows)
    return {
        "threshold_group": threshold_group,
        "completeness_threshold": "{:.4f}".format(completeness_threshold),
        "filter_label": filter_label,
        "total_taxa": total_taxa,
        "min_taxa_required": min_count,
        "kept_files": kept,
        "dropped_files": len(summary_rows) - kept,
        "total_files": len(summary_rows),
        "output_dir": str(combo_root),
        "summary_path": str(summary_path),
    }, summary_rows


def write_filter_summary(path, rows):
    fieldnames = [
        "threshold_group",
        "completeness_threshold",
        "filter_label",
        "uce_locus",
        "input_fasta",
        "output_fasta",
        "total_taxa",
        "min_taxa_required",
        "alignment_taxa",
        "status",
    ]
    with open(path, "w", newline="") as handle:
        writer = csv.DictWriter(handle, fieldnames=fieldnames, delimiter="\t")
        writer.writeheader()
        for row in rows:
            writer.writerow(row)


def write_manifest(path, rows):
    fieldnames = [
        "threshold_group",
        "completeness_threshold",
        "filter_label",
        "total_taxa",
        "min_taxa_required",
        "kept_files",
        "dropped_files",
        "total_files",
        "output_dir",
        "summary_path",
    ]
    with open(path, "w", newline="") as handle:
        writer = csv.DictWriter(handle, fieldnames=fieldnames, delimiter="\t")
        writer.writeheader()
        for row in rows:
            writer.writerow(row)


def main():
    args = get_args()
    groups = threshold_group_labels(args.input_dir, args.threshold_groups)
    completeness_thresholds = parse_thresholds(args.completeness_thresholds)
    output_root = Path(args.output_dir).resolve()
    output_root.mkdir(parents=True, exist_ok=True)

    manifest_rows = []
    all_rows = []
    for group in groups:
        for completeness_threshold in completeness_thresholds:
            manifest_row, summary_rows = copy_alignments_for_threshold(
                args.input_dir,
                args.reference_dir,
                args.output_dir,
                group,
                completeness_threshold,
            )
            manifest_rows.append(manifest_row)
            all_rows.extend(summary_rows)

    write_manifest(output_root / "threshold_manifest.tsv", manifest_rows)
    write_filter_summary(output_root / "all_thresholds_filter_manifest.tsv", all_rows)
    print(
        "Filtered trimmed locus alignments for {} threshold groups across {} completeness thresholds under {}".format(
            len(groups), len(completeness_thresholds), output_root
        )
    )
    print("manifest\t{}".format(output_root / "threshold_manifest.tsv"))


if __name__ == "__main__":
    main()
