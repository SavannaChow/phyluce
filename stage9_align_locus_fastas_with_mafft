#!/usr/bin/env python3

import argparse
import csv
import os
import subprocess
from concurrent.futures import ThreadPoolExecutor, as_completed
from collections import OrderedDict
from pathlib import Path


DATASET_CHOICES = ("complete", "incomplete")
DATASET_ALIASES = {
    "complete": "complete",
    "complete_matrix": "complete",
    "incomplete": "incomplete",
    "incomplete_matrix": "incomplete",
}


def get_args():
    parser = argparse.ArgumentParser(
        description=(
            "Align per-locus FASTA files from stage 08 dataset branches with MAFFT "
            "using phyluce-compatible parameters."
        )
    )
    parser.add_argument(
        "--input-dir",
        required=True,
        help="Stage 08 directory containing dataset subdirectories.",
    )
    parser.add_argument(
        "--output-dir",
        required=True,
        help="Directory for aligned locus FASTA outputs.",
    )
    parser.add_argument(
        "--dataset-modes",
        default=None,
        help=(
            "Optional comma-separated dataset labels to align. Accepts "
            "'complete' and/or 'incomplete'. "
            "Defaults to all datasets found in --input-dir."
        ),
    )
    parser.add_argument(
        "--jobs",
        type=int,
        default=os.cpu_count() or 1,
        help="Maximum number of parallel MAFFT jobs.",
    )
    parser.add_argument(
        "--ambiguous",
        action="store_true",
        default=False,
        help="Keep sequences containing ambiguous N bases. By default these are removed before alignment.",
    )
    parser.add_argument(
        "--matrix-mode",
        choices=["auto", "strict", "incomplete"],
        default="auto",
        help=(
            "Pre-alignment taxon rule. 'strict' requires all dataset taxa, "
            "'incomplete' requires at least 3 taxa, and 'auto' uses strict "
            "for complete and incomplete otherwise."
        ),
    )
    parser.add_argument(
        "--mafft-path",
        default="mafft",
        help="Path to the MAFFT executable.",
    )
    return parser.parse_args()


def parse_dataset_modes(text):
    if not text:
        return None
    labels = []
    seen = set()
    for item in text.split(","):
        value = item.strip()
        if not value:
            continue
        if value not in DATASET_ALIASES:
            raise RuntimeError(
                "Unsupported dataset mode: {}. Expected one of {}".format(
                    value, ", ".join(sorted(DATASET_ALIASES))
                )
            )
        normalized = DATASET_ALIASES[value]
        if normalized not in seen:
            seen.add(normalized)
            labels.append(normalized)
    if not labels:
        raise RuntimeError("No valid dataset modes were provided.")
    return labels


def resolve_dataset_labels(input_dir, dataset_modes_text):
    requested = parse_dataset_modes(dataset_modes_text)
    if requested is not None:
        return requested
    input_root = Path(input_dir).resolve()
    labels = []
    for path in sorted(input_root.iterdir()):
        if not path.is_dir():
            continue
        if (path / "loci").is_dir():
            labels.append(path.name)
    if not labels:
        raise RuntimeError(
            "No dataset directories with loci/ found under {}".format(input_root)
        )
    return labels


def discover_locus_fastas(input_dir, dataset_label):
    loci_dir = Path(input_dir).resolve() / dataset_label / "loci"
    if not loci_dir.is_dir():
        raise RuntimeError("Missing loci directory: {}".format(loci_dir))
    fasta_files = sorted(loci_dir.glob("*.fasta"))
    if not fasta_files:
        raise RuntimeError("No locus FASTA files found under {}".format(loci_dir))
    return fasta_files


def parse_fasta(path):
    records = OrderedDict()
    current_header = None
    chunks = []
    with open(path) as handle:
        for raw_line in handle:
            line = raw_line.strip()
            if not line:
                continue
            if line.startswith(">"):
                if current_header is not None:
                    records[current_header] = "".join(chunks)
                current_header = line[1:]
                chunks = []
            else:
                chunks.append(line)
    if current_header is not None:
        records[current_header] = "".join(chunks)
    return records


def write_fasta(path, records):
    with open(path, "w") as handle:
        for header, sequence in records.items():
            handle.write(">{}\n".format(header))
            handle.write("{}\n".format(sequence))


def parse_sample_id_from_header(header):
    record_id = header.split()[0]
    if record_id.startswith("_R_"):
        record_id = record_id[3:]
    return record_id.split("|")[0]


def read_dataset_taxa(input_dir, dataset_label):
    fasta_files = discover_locus_fastas(input_dir, dataset_label)
    taxa = set()
    for fasta_path in fasta_files:
        taxa.update(
            parse_sample_id_from_header(header)
            for header in parse_fasta(fasta_path).keys()
        )
    if not taxa:
        raise RuntimeError("No taxa found across dataset {}".format(dataset_label))
    return sorted(taxa)


def resolve_matrix_mode(matrix_mode, dataset_label):
    if matrix_mode != "auto":
        return matrix_mode
    if DATASET_ALIASES.get(dataset_label, dataset_label) == "complete":
        return "strict"
    return "incomplete"


def prefilter_locus(input_fasta, prefiltered_fasta, dataset_label, total_taxa, matrix_mode, allow_ambiguous):
    records = parse_fasta(input_fasta)
    input_taxa = len(records)
    retained = OrderedDict()
    ambiguous_removed = []
    for header, sequence in records.items():
        if not allow_ambiguous and "N" in sequence.upper():
            ambiguous_removed.append(header)
            continue
        retained[header] = sequence
    retained_taxa = len(retained)
    effective_mode = resolve_matrix_mode(matrix_mode, dataset_label)
    status = "ready"
    reason = ""
    if effective_mode == "strict":
        if retained_taxa < total_taxa:
            status = "dropped"
            reason = "too_few_taxa_strict"
    else:
        if retained_taxa < 3:
            status = "dropped"
            reason = "too_few_taxa_incomplete"
    if status == "ready":
        prefiltered_fasta.parent.mkdir(parents=True, exist_ok=True)
        write_fasta(prefiltered_fasta, retained)
    return {
        "input_taxa": input_taxa,
        "retained_taxa": retained_taxa,
        "ambiguous_removed": len(ambiguous_removed),
        "ambiguous_removed_ids": ",".join(ambiguous_removed),
        "matrix_mode": effective_mode,
        "status": status,
        "reason": reason,
    }


def run_mafft(input_fasta, output_fasta, mafft_path):
    command = [
        str(mafft_path),
        "--adjustdirection",
        "--maxiterate",
        "1000",
        str(input_fasta),
    ]
    process = subprocess.run(
        command,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        universal_newlines=True,
        check=False,
    )
    if process.returncode != 0:
        raise RuntimeError(
            "MAFFT failed for {}:\n{}".format(input_fasta, process.stderr.strip())
        )
    records = OrderedDict()
    current_header = None
    chunks = []
    for raw_line in process.stdout.splitlines():
        line = raw_line.strip()
        if not line:
            continue
        if line.startswith(">"):
            if current_header is not None:
                records[current_header] = "".join(chunks)
            current_header = line[1:]
            chunks = []
        else:
            chunks.append(line)
    if current_header is not None:
        records[current_header] = "".join(chunks)
    if not records:
        raise RuntimeError("MAFFT produced no FASTA records for {}".format(input_fasta))
    write_fasta(output_fasta, records)
    return process.stderr


def align_dataset(input_dir, output_dir, dataset_label, jobs, matrix_mode, allow_ambiguous, mafft_path):
    fasta_files = discover_locus_fastas(input_dir, dataset_label)
    total_taxa = len(read_dataset_taxa(input_dir, dataset_label))
    dataset_output = Path(output_dir).resolve() / dataset_label
    prefiltered_dir = dataset_output / "prefiltered_fastas"
    alignments_dir = dataset_output / "alignments"
    alignments_dir.mkdir(parents=True, exist_ok=True)

    summary_rows = []
    pending = []
    for fasta_path in fasta_files:
        prefiltered_path = prefiltered_dir / fasta_path.name
        output_path = alignments_dir / fasta_path.name
        prefilter_result = prefilter_locus(
            fasta_path,
            prefiltered_path,
            dataset_label,
            total_taxa,
            matrix_mode,
            allow_ambiguous,
        )
        locus_row = {
            "dataset_label": dataset_label,
            "uce_locus": fasta_path.stem,
            "input_fasta": str(fasta_path),
            "prefiltered_fasta": str(prefiltered_path) if prefilter_result["status"] == "ready" else "",
            "output_fasta": str(output_path) if prefilter_result["status"] != "dropped" else "",
            "total_taxa": total_taxa,
            "input_taxa": prefilter_result["input_taxa"],
            "retained_taxa": prefilter_result["retained_taxa"],
            "ambiguous_removed": prefilter_result["ambiguous_removed"],
            "ambiguous_removed_ids": prefilter_result["ambiguous_removed_ids"],
            "matrix_mode": prefilter_result["matrix_mode"],
        }
        if prefilter_result["status"] == "dropped":
            locus_row["status"] = "dropped"
            locus_row["reason"] = prefilter_result["reason"]
            summary_rows.append(locus_row)
            continue
        if output_path.exists():
            locus_row["status"] = "existing"
            locus_row["reason"] = ""
            summary_rows.append(locus_row)
        else:
            pending.append((prefiltered_path, output_path, locus_row))

    ready_count = len(pending)
    dropped_count = sum(1 for row in summary_rows if row["status"] == "dropped")
    existing_count = sum(1 for row in summary_rows if row["status"] == "existing")
    print(
        "[stage9:{}] {} loci total; {} ready for MAFFT, {} existing, {} dropped in prefilter".format(
            dataset_label,
            len(fasta_files),
            ready_count,
            existing_count,
            dropped_count,
        ),
        flush=True,
    )

    with ThreadPoolExecutor(max_workers=max(1, jobs)) as executor:
        futures = {
            executor.submit(run_mafft, prefiltered_path, output_path, mafft_path): (
                prefiltered_path,
                output_path,
                locus_row,
            )
            for prefiltered_path, output_path, locus_row in pending
        }
        completed = 0
        progress_interval = max(1, min(25, ready_count // 10 if ready_count else 1))
        for future in as_completed(futures):
            _, _, locus_row = futures[future]
            future.result()
            locus_row["status"] = "aligned"
            locus_row["reason"] = ""
            summary_rows.append(locus_row)
            completed += 1
            if completed == ready_count or completed % progress_interval == 0:
                print(
                    "[stage9:{}] MAFFT progress {}/{}".format(
                        dataset_label, completed, ready_count
                    ),
                    flush=True,
                )

    summary_rows.sort(key=lambda row: row["uce_locus"])
    return summary_rows


def write_alignment_summary(path, rows):
    fieldnames = [
        "dataset_label",
        "uce_locus",
        "input_fasta",
        "prefiltered_fasta",
        "output_fasta",
        "total_taxa",
        "input_taxa",
        "retained_taxa",
        "ambiguous_removed",
        "ambiguous_removed_ids",
        "matrix_mode",
        "status",
        "reason",
    ]
    with open(path, "w", newline="") as handle:
        writer = csv.DictWriter(handle, fieldnames=fieldnames, delimiter="\t")
        writer.writeheader()
        for row in rows:
            writer.writerow(row)


def write_dataset_summary(path, rows):
    fieldnames = [
        "dataset_label",
        "aligned_files",
        "existing_files",
        "dropped_files",
        "total_files",
        "matrix_mode",
        "ambiguous_mode",
        "output_dir",
        "summary_path",
    ]
    with open(path, "w", newline="") as handle:
        writer = csv.DictWriter(handle, fieldnames=fieldnames, delimiter="\t")
        writer.writeheader()
        for row in rows:
            writer.writerow(row)


def main():
    args = get_args()
    dataset_labels = resolve_dataset_labels(args.input_dir, args.dataset_modes)
    output_root = Path(args.output_dir).resolve()
    output_root.mkdir(parents=True, exist_ok=True)

    all_rows = []
    dataset_rows = []
    for dataset_label in dataset_labels:
        print("[stage9:{}] starting alignment".format(dataset_label), flush=True)
        summary_rows = align_dataset(
            args.input_dir,
            args.output_dir,
            dataset_label,
            args.jobs,
            args.matrix_mode,
            args.ambiguous,
            args.mafft_path,
        )
        dataset_dir = output_root / dataset_label
        summary_path = dataset_dir / "alignment_summary.tsv"
        write_alignment_summary(summary_path, summary_rows)
        all_rows.extend(summary_rows)
        dataset_rows.append(
            {
                "dataset_label": dataset_label,
                "aligned_files": sum(1 for row in summary_rows if row["status"] == "aligned"),
                "existing_files": sum(1 for row in summary_rows if row["status"] == "existing"),
                "dropped_files": sum(1 for row in summary_rows if row["status"] == "dropped"),
                "total_files": len(summary_rows),
                "matrix_mode": resolve_matrix_mode(args.matrix_mode, dataset_label),
                "ambiguous_mode": "keep" if args.ambiguous else "drop",
                "output_dir": str(dataset_dir),
                "summary_path": str(summary_path),
            }
        )
        print("[stage9:{}] alignment complete".format(dataset_label), flush=True)

    write_alignment_summary(output_root / "all_datasets_alignment_manifest.tsv", all_rows)
    write_dataset_summary(output_root / "dataset_manifest.tsv", dataset_rows)
    print("Aligned locus FASTA files for {} datasets under {}".format(len(dataset_labels), output_root))
    print("manifest\t{}".format(output_root / "dataset_manifest.tsv"))


if __name__ == "__main__":
    main()
