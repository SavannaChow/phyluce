#!/usr/bin/env python3

import argparse
import csv
import os
from collections import defaultdict, OrderedDict
from pathlib import Path


AGGREGATE_REQUIRED_FIELDS = {
    "sample_id",
    "uce_locus",
    "target_name",
    "target_start",
    "target_end",
    "strand",
    "probe_hit_count",
    "query_names",
    "filtered_loci_path",
}


def get_args():
    parser = argparse.ArgumentParser(
        description=(
            "Export one FASTA per UCE locus from aggregated loci tables and "
            "sample-level extracted FASTA files."
        )
    )
    parser.add_argument(
        "--aggregated-loci",
        required=True,
        help="Aggregated long-format loci table from stage 07.",
    )
    parser.add_argument(
        "--extract-dir",
        required=True,
        help="Stage 06 directory containing <sample>/<sample>.filtered.fasta files.",
    )
    parser.add_argument(
        "--output-dir",
        required=True,
        help="Directory for per-locus FASTA outputs.",
    )
    parser.add_argument(
        "--sample-fasta-suffix",
        default=".filtered.fasta",
        help="Filename suffix used for per-sample FASTA files in --extract-dir.",
    )
    parser.add_argument(
        "--thresholds",
        default="1.0",
        help=(
            "Comma-separated minimum sample proportions to export, e.g. "
            "'1.0,0.9,0.75'. 1.0 corresponds to a complete matrix."
        ),
    )
    return parser.parse_args()


def load_aggregated_loci(path):
    rows = []
    with open(path, newline="") as handle:
        reader = csv.DictReader(handle, delimiter="\t")
        if reader.fieldnames is None or not AGGREGATE_REQUIRED_FIELDS.issubset(
            set(reader.fieldnames)
        ):
            raise RuntimeError("Unexpected aggregated loci schema in {}".format(path))
        for row in reader:
            rows.append(
                {
                    "sample_id": row["sample_id"].strip(),
                    "uce_locus": row["uce_locus"].strip(),
                }
            )
    if not rows:
        raise RuntimeError("No loci rows found in {}".format(path))
    return rows


def parse_thresholds(text):
    thresholds = []
    seen = set()
    for item in text.split(","):
        value = item.strip()
        if not value:
            continue
        threshold = float(value)
        if threshold <= 0 or threshold > 1:
            raise RuntimeError(
                "Threshold values must be > 0 and <= 1. Invalid value: {}".format(
                    value
                )
            )
        key = round(threshold, 6)
        if key not in seen:
            seen.add(key)
            thresholds.append(threshold)
    if not thresholds:
        raise RuntimeError("No valid thresholds were provided.")
    return sorted(thresholds, reverse=True)


def parse_fasta(path):
    records = OrderedDict()
    current_header = None
    chunks = []
    with open(path) as handle:
        for raw_line in handle:
            line = raw_line.strip()
            if not line:
                continue
            if line.startswith(">"):
                if current_header is not None:
                    records[current_header] = "".join(chunks)
                current_header = line[1:]
                chunks = []
            else:
                chunks.append(line)
    if current_header is not None:
        records[current_header] = "".join(chunks)
    return records


def parse_detailed_header(header):
    record_id = header.split()[0]
    parts = record_id.split("|")
    if len(parts) < 2:
        raise RuntimeError("Unexpected FASTA header format: {}".format(header))
    return parts[0], parts[1]


def build_sequence_index(extract_dir, suffix):
    extract_root = Path(extract_dir).resolve()
    files = sorted(extract_root.rglob("*{}".format(suffix)))
    if not files:
        raise RuntimeError(
            "No sample FASTA files ending with {} found under {}".format(
                suffix, extract_root
            )
        )
    index = {}
    for path in files:
        for header, sequence in parse_fasta(path).items():
            sample_id, uce_locus = parse_detailed_header(header)
            key = (sample_id, uce_locus)
            if key in index:
                raise RuntimeError(
                    "Duplicate FASTA record for sample/locus pair {} in {}".format(
                        key, path
                    )
                )
            index[key] = sequence
    return index


def threshold_label(threshold):
    if abs(threshold - 1.0) < 1e-9:
        return "complete_matrix"
    return "coverage_{:03d}".format(int(round(threshold * 100)))


def read_summary(path):
    if not Path(path).is_file():
        return []
    with open(path, newline="") as handle:
        return list(csv.DictReader(handle, delimiter="\t"))


def read_threshold_summary(path):
    if not Path(path).is_file():
        return []
    with open(path, newline="") as handle:
        return list(csv.DictReader(handle, delimiter="\t"))


def write_locus_fastas(rows, sequence_index, output_dir, thresholds):
    grouped = defaultdict(list)
    for row in rows:
        grouped[row["uce_locus"]].append(row["sample_id"])

    output_root = Path(output_dir).resolve()
    output_root.mkdir(parents=True, exist_ok=True)
    total_samples = len({row["sample_id"] for row in rows})
    all_summary_rows = read_summary(output_root / "all_thresholds_locus_fasta_summary.tsv")
    threshold_summary_rows = read_threshold_summary(output_root / "threshold_summary.tsv")
    existing_threshold_labels = {
        row["threshold_label"] for row in threshold_summary_rows
    }

    for threshold in thresholds:
        kept = 0
        label = threshold_label(threshold)
        threshold_dir = output_root / label
        if label in existing_threshold_labels:
            continue
        loci_root = threshold_dir / "loci"
        loci_root.mkdir(parents=True, exist_ok=True)
        summary_rows = []
        for locus in sorted(grouped):
            samples = sorted(grouped[locus])
            present_proportion = len(samples) / float(total_samples) if total_samples else 0.0
            if present_proportion + 1e-12 < threshold:
                continue
            found = []
            missing = []
            for sample_id in samples:
                key = (sample_id, locus)
                sequence = sequence_index.get(key)
                if sequence is None:
                    missing.append(sample_id)
                else:
                    found.append((sample_id, sequence))
            fasta_path = loci_root / "{}.fasta".format(locus)
            with open(fasta_path, "w") as handle:
                for sample_id, sequence in found:
                    handle.write(">{}\n".format(sample_id))
                    handle.write("{}\n".format(sequence))
            summary_rows.append(
                {
                    "threshold": "{:.4f}".format(threshold),
                    "threshold_label": label,
                    "uce_locus": locus,
                    "samples_in_aggregate": len(samples),
                    "total_samples": total_samples,
                    "sample_proportion": "{:.4f}".format(present_proportion),
                    "sequences_written": len(found),
                    "missing_sequences": len(missing),
                    "sample_ids_present": ",".join(sample for sample, _ in found),
                    "sample_ids_missing": ",".join(missing),
                    "fasta_path": str(fasta_path),
                }
            )
            kept += 1
        summary_path = threshold_dir / "locus_fasta_summary.tsv"
        write_summary(summary_path, summary_rows)
        all_summary_rows.extend(summary_rows)
        threshold_summary_rows.append(
            {
                "threshold": "{:.4f}".format(threshold),
                "threshold_label": label,
                "loci_kept": kept,
                "output_dir": str(threshold_dir),
                "summary_path": str(summary_path),
            }
        )
    all_summary_rows.sort(key=lambda row: (row["threshold_label"], row["uce_locus"]))
    threshold_summary_rows.sort(key=lambda row: row["threshold_label"])
    return all_summary_rows, threshold_summary_rows


def write_summary(path, rows):
    fieldnames = [
        "threshold",
        "threshold_label",
        "uce_locus",
        "samples_in_aggregate",
        "total_samples",
        "sample_proportion",
        "sequences_written",
        "missing_sequences",
        "sample_ids_present",
        "sample_ids_missing",
        "fasta_path",
    ]
    with open(path, "w", newline="") as handle:
        writer = csv.DictWriter(handle, fieldnames=fieldnames, delimiter="\t")
        writer.writeheader()
        for row in rows:
            writer.writerow(row)


def write_threshold_summary(path, rows):
    fieldnames = [
        "threshold",
        "threshold_label",
        "loci_kept",
        "output_dir",
        "summary_path",
    ]
    with open(path, "w", newline="") as handle:
        writer = csv.DictWriter(handle, fieldnames=fieldnames, delimiter="\t")
        writer.writeheader()
        for row in rows:
            writer.writerow(row)


def main():
    args = get_args()
    rows = load_aggregated_loci(args.aggregated_loci)
    thresholds = parse_thresholds(args.thresholds)
    sequence_index = build_sequence_index(args.extract_dir, args.sample_fasta_suffix)
    summary_rows, threshold_summary_rows = write_locus_fastas(
        rows, sequence_index, args.output_dir, thresholds
    )
    summary_path = Path(args.output_dir).resolve() / "all_thresholds_locus_fasta_summary.tsv"
    threshold_summary_path = Path(args.output_dir).resolve() / "threshold_summary.tsv"
    write_summary(summary_path, summary_rows)
    write_threshold_summary(threshold_summary_path, threshold_summary_rows)
    print(
        "Exported locus FASTA files for {} thresholds under {}".format(
            len(thresholds), Path(args.output_dir).resolve()
        )
    )
    print("summary\t{}".format(summary_path))
    print("threshold_summary\t{}".format(threshold_summary_path))


if __name__ == "__main__":
    main()
