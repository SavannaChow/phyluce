#!/usr/bin/env python3

import argparse
import csv
import os
import subprocess
from concurrent.futures import ThreadPoolExecutor, as_completed
from collections import OrderedDict
from pathlib import Path


def get_args():
    parser = argparse.ArgumentParser(
        description=(
            "Align per-locus FASTA files with MAFFT using phyluce-compatible "
            "parameters."
        )
    )
    parser.add_argument(
        "--input-dir",
        required=True,
        help="Stage 08 directory containing threshold subdirectories.",
    )
    parser.add_argument(
        "--output-dir",
        required=True,
        help="Directory for aligned locus FASTA outputs.",
    )
    parser.add_argument(
        "--thresholds",
        default=None,
        help=(
            "Optional comma-separated threshold labels or values to align, e.g. "
            "'complete_matrix,coverage_090' or '1.0,0.9'. Defaults to all "
            "thresholds found in --input-dir."
        ),
    )
    parser.add_argument(
        "--jobs",
        type=int,
        default=os.cpu_count() or 1,
        help="Maximum number of parallel MAFFT jobs.",
    )
    parser.add_argument(
        "--ambiguous",
        action="store_true",
        default=False,
        help="Keep sequences containing ambiguous N bases. By default these are removed before alignment.",
    )
    parser.add_argument(
        "--matrix-mode",
        choices=["auto", "strict", "incomplete"],
        default="auto",
        help=(
            "Pre-alignment taxon rule. 'strict' requires all expected taxa, "
            "'incomplete' requires at least 3 taxa, and 'auto' uses strict "
            "for complete_matrix and incomplete otherwise."
        ),
    )
    parser.add_argument(
        "--mafft-path",
        default="mafft",
        help="Path to the MAFFT executable.",
    )
    return parser.parse_args()


def threshold_label_from_value(value):
    threshold = float(value)
    if threshold <= 0 or threshold > 1:
        raise RuntimeError("Threshold values must be > 0 and <= 1: {}".format(value))
    if abs(threshold - 1.0) < 1e-9:
        return "complete_matrix"
    return "coverage_{:03d}".format(int(round(threshold * 100)))


def resolve_threshold_labels(input_dir, thresholds_text):
    input_root = Path(input_dir).resolve()
    if thresholds_text:
        labels = []
        for item in thresholds_text.split(","):
            value = item.strip()
            if not value:
                continue
            if value.startswith("coverage_") or value == "complete_matrix":
                labels.append(value)
            else:
                labels.append(threshold_label_from_value(value))
        if not labels:
            raise RuntimeError("No valid thresholds were provided.")
        return labels

    labels = []
    for path in sorted(input_root.iterdir()):
        if not path.is_dir():
            continue
        if (path / "loci").is_dir():
            labels.append(path.name)
    if not labels:
        raise RuntimeError("No threshold directories with loci/ found under {}".format(input_root))
    return labels


def discover_locus_fastas(input_dir, threshold_label):
    loci_dir = Path(input_dir).resolve() / threshold_label / "loci"
    if not loci_dir.is_dir():
        raise RuntimeError("Missing loci directory: {}".format(loci_dir))
    fasta_files = sorted(loci_dir.glob("*.fasta"))
    if not fasta_files:
        raise RuntimeError("No locus FASTA files found under {}".format(loci_dir))
    return fasta_files


def parse_fasta(path):
    records = OrderedDict()
    current_header = None
    chunks = []
    with open(path) as handle:
        for raw_line in handle:
            line = raw_line.strip()
            if not line:
                continue
            if line.startswith(">"):
                if current_header is not None:
                    records[current_header] = "".join(chunks)
                current_header = line[1:]
                chunks = []
            else:
                chunks.append(line)
    if current_header is not None:
        records[current_header] = "".join(chunks)
    return records


def write_fasta(path, records):
    with open(path, "w") as handle:
        for header, sequence in records.items():
            handle.write(">{}\n".format(header))
            handle.write("{}\n".format(sequence))


def read_locus_summary(input_dir, threshold_label):
    summary_path = Path(input_dir).resolve() / threshold_label / "locus_fasta_summary.tsv"
    if not summary_path.is_file():
        raise RuntimeError("Missing locus summary for {}: {}".format(threshold_label, summary_path))
    rows = []
    with open(summary_path, newline="") as handle:
        reader = csv.DictReader(handle, delimiter="\t")
        for row in reader:
            rows.append(row)
    if not rows:
        raise RuntimeError("No locus rows found in {}".format(summary_path))
    try:
        total_samples = max(int(row["total_samples"]) for row in rows)
    except KeyError as exc:
        raise RuntimeError("Unexpected stage 08 summary schema in {}".format(summary_path)) from exc
    return total_samples


def resolve_matrix_mode(matrix_mode, threshold_label):
    if matrix_mode != "auto":
        return matrix_mode
    if threshold_label == "complete_matrix":
        return "strict"
    return "incomplete"


def prefilter_locus(input_fasta, prefiltered_fasta, threshold_label, total_taxa, matrix_mode, allow_ambiguous):
    records = parse_fasta(input_fasta)
    input_taxa = len(records)
    retained = OrderedDict()
    ambiguous_removed = []
    for header, sequence in records.items():
        if not allow_ambiguous and "N" in sequence.upper():
            ambiguous_removed.append(header)
            continue
        retained[header] = sequence
    retained_taxa = len(retained)
    effective_mode = resolve_matrix_mode(matrix_mode, threshold_label)
    status = "ready"
    reason = ""
    if effective_mode == "strict":
        if retained_taxa < total_taxa:
            status = "dropped"
            reason = "too_few_taxa_strict"
    else:
        if retained_taxa < 3:
            status = "dropped"
            reason = "too_few_taxa_incomplete"
    if status == "ready":
        prefiltered_fasta.parent.mkdir(parents=True, exist_ok=True)
        write_fasta(prefiltered_fasta, retained)
    return {
        "input_taxa": input_taxa,
        "retained_taxa": retained_taxa,
        "ambiguous_removed": len(ambiguous_removed),
        "ambiguous_removed_ids": ",".join(ambiguous_removed),
        "matrix_mode": effective_mode,
        "status": status,
        "reason": reason,
    }


def run_mafft(input_fasta, output_fasta, mafft_path):
    command = [
        str(mafft_path),
        "--adjustdirection",
        "--maxiterate",
        "1000",
        str(input_fasta),
    ]
    process = subprocess.run(
        command,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
        check=False,
    )
    if process.returncode != 0:
        raise RuntimeError(
            "MAFFT failed for {}:\n{}".format(input_fasta, process.stderr.strip())
        )
    with open(output_fasta, "w") as handle:
        handle.write(process.stdout)
    return process.stderr


def align_threshold(input_dir, output_dir, threshold_label, jobs, matrix_mode, allow_ambiguous, mafft_path):
    fasta_files = discover_locus_fastas(input_dir, threshold_label)
    total_taxa = read_locus_summary(input_dir, threshold_label)
    threshold_output = Path(output_dir).resolve() / threshold_label
    prefiltered_dir = threshold_output / "prefiltered_fastas"
    alignments_dir = threshold_output / "alignments"
    alignments_dir.mkdir(parents=True, exist_ok=True)

    summary_rows = []
    pending = []
    for fasta_path in fasta_files:
        prefiltered_path = prefiltered_dir / fasta_path.name
        output_path = alignments_dir / fasta_path.name
        prefilter_result = prefilter_locus(
            fasta_path,
            prefiltered_path,
            threshold_label,
            total_taxa,
            matrix_mode,
            allow_ambiguous,
        )
        locus_row = {
            "threshold_label": threshold_label,
            "uce_locus": fasta_path.stem,
            "input_fasta": str(fasta_path),
            "prefiltered_fasta": str(prefiltered_path) if prefilter_result["status"] == "ready" else "",
            "output_fasta": str(output_path) if prefilter_result["status"] != "dropped" else "",
            "total_taxa": total_taxa,
            "input_taxa": prefilter_result["input_taxa"],
            "retained_taxa": prefilter_result["retained_taxa"],
            "ambiguous_removed": prefilter_result["ambiguous_removed"],
            "ambiguous_removed_ids": prefilter_result["ambiguous_removed_ids"],
            "matrix_mode": prefilter_result["matrix_mode"],
        }
        if prefilter_result["status"] == "dropped":
            locus_row["status"] = "dropped"
            locus_row["reason"] = prefilter_result["reason"]
            summary_rows.append(locus_row)
            continue
        if output_path.exists():
            locus_row["status"] = "existing"
            locus_row["reason"] = ""
            summary_rows.append(locus_row)
        else:
            pending.append((prefiltered_path, output_path, locus_row))

    with ThreadPoolExecutor(max_workers=max(1, jobs)) as executor:
        futures = {
            executor.submit(run_mafft, prefiltered_path, output_path, mafft_path): (
                prefiltered_path,
                output_path,
                locus_row,
            )
            for prefiltered_path, output_path, locus_row in pending
        }
        for future in as_completed(futures):
            _, output_path, locus_row = futures[future]
            future.result()
            locus_row["status"] = "aligned"
            locus_row["reason"] = ""
            summary_rows.append(locus_row)

    summary_rows.sort(key=lambda row: row["uce_locus"])
    return summary_rows


def write_alignment_summary(path, rows):
    fieldnames = [
        "threshold_label",
        "uce_locus",
        "input_fasta",
        "prefiltered_fasta",
        "output_fasta",
        "total_taxa",
        "input_taxa",
        "retained_taxa",
        "ambiguous_removed",
        "ambiguous_removed_ids",
        "matrix_mode",
        "status",
        "reason",
    ]
    with open(path, "w", newline="") as handle:
        writer = csv.DictWriter(handle, fieldnames=fieldnames, delimiter="\t")
        writer.writeheader()
        for row in rows:
            writer.writerow(row)


def write_threshold_summary(path, rows):
    fieldnames = [
        "threshold_label",
        "aligned_files",
        "existing_files",
        "dropped_files",
        "total_files",
        "matrix_mode",
        "ambiguous_mode",
        "output_dir",
        "summary_path",
    ]
    with open(path, "w", newline="") as handle:
        writer = csv.DictWriter(handle, fieldnames=fieldnames, delimiter="\t")
        writer.writeheader()
        for row in rows:
            writer.writerow(row)


def main():
    args = get_args()
    threshold_labels = resolve_threshold_labels(args.input_dir, args.thresholds)
    output_root = Path(args.output_dir).resolve()
    output_root.mkdir(parents=True, exist_ok=True)

    all_rows = []
    threshold_rows = []
    for threshold_label in threshold_labels:
        summary_rows = align_threshold(
            args.input_dir,
            args.output_dir,
            threshold_label,
            args.jobs,
            args.matrix_mode,
            args.ambiguous,
            args.mafft_path,
        )
        threshold_dir = output_root / threshold_label
        summary_path = threshold_dir / "alignment_summary.tsv"
        write_alignment_summary(summary_path, summary_rows)
        all_rows.extend(summary_rows)
        aligned = sum(1 for row in summary_rows if row["status"] == "aligned")
        existing = sum(1 for row in summary_rows if row["status"] == "existing")
        dropped = sum(1 for row in summary_rows if row["status"] == "dropped")
        threshold_rows.append(
            {
                "threshold_label": threshold_label,
                "aligned_files": aligned,
                "existing_files": existing,
                "dropped_files": dropped,
                "total_files": len(summary_rows),
                "matrix_mode": resolve_matrix_mode(args.matrix_mode, threshold_label),
                "ambiguous_mode": "keep" if args.ambiguous else "drop",
                "output_dir": str(threshold_dir),
                "summary_path": str(summary_path),
            }
        )

    write_alignment_summary(
        output_root / "all_thresholds_alignment_manifest.tsv", all_rows
    )
    write_threshold_summary(output_root / "threshold_manifest.tsv", threshold_rows)
    print("Aligned locus FASTA files for {} thresholds under {}".format(len(threshold_labels), output_root))
    print("manifest\t{}".format(output_root / "threshold_manifest.tsv"))


if __name__ == "__main__":
    main()
