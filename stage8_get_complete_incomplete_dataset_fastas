#!/usr/bin/env python3

import argparse
import csv
from collections import OrderedDict, defaultdict
from pathlib import Path


DATASET_CHOICES = ("complete", "incomplete")


def get_args():
    parser = argparse.ArgumentParser(
        description=(
            "Materialize complete and/or incomplete dataset FASTAs from stage 07 "
            "aggregate outputs and stage 06 extracted sample FASTAs."
        )
    )
    parser.add_argument(
        "--aggregate-dir",
        required=True,
        help="Stage 07 aggregate directory containing *.manifest.tsv outputs.",
    )
    parser.add_argument(
        "--extract-dir",
        required=True,
        help="Stage 06 directory containing <sample>/<sample>.filtered.fasta files.",
    )
    parser.add_argument(
        "--output-dir",
        required=True,
        help="Directory for dataset FASTA outputs.",
    )
    parser.add_argument(
        "--prefix",
        required=True,
        help="Filename prefix shared by the stage 07 aggregate outputs.",
    )
    parser.add_argument(
        "--dataset-modes",
        default="complete,incomplete",
        help=(
            "Comma-separated dataset modes to materialize. Accepts "
            "'complete' and/or 'incomplete'."
        ),
    )
    parser.add_argument(
        "--sample-fasta-suffix",
        default=".filtered.fasta",
        help="Filename suffix used for per-sample FASTA files in --extract-dir.",
    )
    return parser.parse_args()


def parse_dataset_modes(text):
    labels = []
    seen = set()
    for item in text.split(","):
        value = item.strip()
        if not value:
            continue
        if value not in DATASET_CHOICES:
            raise RuntimeError(
                "Unsupported dataset mode: {}. Expected one of {}".format(
                    value, ", ".join(DATASET_CHOICES)
                )
            )
        if value not in seen:
            seen.add(value)
            labels.append(value)
    if not labels:
        raise RuntimeError("No valid dataset modes were provided.")
    return labels


def parse_fasta(path):
    records = OrderedDict()
    current_header = None
    chunks = []
    with open(path) as handle:
        for raw_line in handle:
            line = raw_line.strip()
            if not line:
                continue
            if line.startswith(">"):
                if current_header is not None:
                    records[current_header] = "".join(chunks)
                current_header = line[1:]
                chunks = []
            else:
                chunks.append(line)
    if current_header is not None:
        records[current_header] = "".join(chunks)
    return records


def parse_detailed_header(header):
    record_id = header.split()[0]
    parts = record_id.split("|")
    if len(parts) < 2:
        raise RuntimeError("Unexpected FASTA header format: {}".format(header))
    return parts[0], parts[1]


def build_sequence_index(extract_dir, suffix):
    extract_root = Path(extract_dir).resolve()
    files = sorted(extract_root.rglob("*{}".format(suffix)))
    if not files:
        raise RuntimeError(
            "No sample FASTA files ending with {} found under {}".format(
                suffix, extract_root
            )
        )
    index = {}
    for path in files:
        for header, sequence in parse_fasta(path).items():
            sample_id, uce_locus = parse_detailed_header(header)
            key = (sample_id, uce_locus)
            if key in index:
                raise RuntimeError(
                    "Duplicate FASTA record for sample/locus pair {} in {}".format(
                        key, path
                    )
                )
            index[key] = {"header": header, "sequence": sequence}
    return index


def read_dataset_manifest(path):
    rows = []
    with open(path, newline="") as handle:
        reader = csv.DictReader(handle, delimiter="\t")
        required = {"dataset_mode", "sample_id", "uce_locus"}
        if reader.fieldnames is None or not required.issubset(set(reader.fieldnames)):
            raise RuntimeError("Unexpected dataset manifest schema in {}".format(path))
        for row in reader:
            rows.append(
                {
                    "dataset_mode": row["dataset_mode"].strip(),
                    "sample_id": row["sample_id"].strip(),
                    "uce_locus": row["uce_locus"].strip(),
                }
            )
    if not rows:
        raise RuntimeError("No dataset rows found in {}".format(path))
    return rows


def write_fasta(path, records):
    with open(path, "w") as handle:
        for header, sequence in records.items():
            handle.write(">{}\n".format(header))
            handle.write("{}\n".format(sequence))


def write_dataset_summary(path, rows):
    fieldnames = [
        "dataset_mode",
        "uce_locus",
        "samples_expected",
        "sequences_written",
        "missing_sequences",
        "sample_ids_present",
        "sample_ids_missing",
        "locus_fasta_path",
    ]
    with open(path, "w", newline="") as handle:
        writer = csv.DictWriter(handle, fieldnames=fieldnames, delimiter="\t")
        writer.writeheader()
        for row in rows:
            writer.writerow(row)


def write_dataset_manifest_summary(path, rows):
    fieldnames = [
        "dataset_mode",
        "dataset_label",
        "loci_written",
        "monolithic_fasta",
        "loci_dir",
        "summary_path",
    ]
    with open(path, "w", newline="") as handle:
        writer = csv.DictWriter(handle, fieldnames=fieldnames, delimiter="\t")
        writer.writeheader()
        for row in rows:
            writer.writerow(row)


def materialize_dataset(dataset_label, rows, sequence_index, output_root):
    grouped = defaultdict(list)
    for row in rows:
        grouped[row["uce_locus"]].append(row["sample_id"])

    dataset_root = Path(output_root).resolve() / dataset_label
    loci_root = dataset_root / "loci"
    loci_root.mkdir(parents=True, exist_ok=True)
    monolithic_path = dataset_root / "{}.fasta".format(dataset_label)
    summary_path = dataset_root / "locus_fasta_summary.tsv"

    monolithic_records = OrderedDict()
    summary_rows = []
    for locus in sorted(grouped):
        samples = sorted(grouped[locus])
        locus_records = OrderedDict()
        missing = []
        for sample_id in samples:
            key = (sample_id, locus)
            record = sequence_index.get(key)
            if record is None:
                missing.append(sample_id)
                continue
            locus_records[record["header"]] = record["sequence"]
            monolithic_records[record["header"]] = record["sequence"]
        locus_fasta_path = loci_root / "{}.fasta".format(locus)
        write_fasta(locus_fasta_path, locus_records)
        summary_rows.append(
            {
                "dataset_mode": dataset_label,
                "uce_locus": locus,
                "samples_expected": len(samples),
                "sequences_written": len(locus_records),
                "missing_sequences": len(missing),
                "sample_ids_present": ",".join(
                    sample_id for sample_id in samples if sample_id not in missing
                ),
                "sample_ids_missing": ",".join(missing),
                "locus_fasta_path": str(locus_fasta_path),
            }
        )

    write_fasta(monolithic_path, monolithic_records)
    write_dataset_summary(summary_path, summary_rows)
    return {
        "dataset_mode": dataset_label,
        "dataset_label": dataset_label,
        "loci_written": len(summary_rows),
        "monolithic_fasta": str(monolithic_path),
        "loci_dir": str(loci_root),
        "summary_path": str(summary_path),
    }, summary_rows


def main():
    args = get_args()
    aggregate_root = Path(args.aggregate_dir).resolve()
    output_root = Path(args.output_dir).resolve()
    output_root.mkdir(parents=True, exist_ok=True)
    sequence_index = build_sequence_index(args.extract_dir, args.sample_fasta_suffix)
    dataset_modes = parse_dataset_modes(args.dataset_modes)

    manifest_rows = []
    all_rows = []
    for dataset_label in dataset_modes:
        manifest_path = aggregate_root / "{}.{}.manifest.tsv".format(
            args.prefix, dataset_label
        )
        rows = read_dataset_manifest(manifest_path)
        manifest_row, summary_rows = materialize_dataset(
            dataset_label, rows, sequence_index, output_root
        )
        manifest_rows.append(manifest_row)
        all_rows.extend(summary_rows)

    write_dataset_summary(output_root / "all_datasets_locus_fasta_manifest.tsv", all_rows)
    write_dataset_manifest_summary(output_root / "dataset_manifest.tsv", manifest_rows)
    print(
        "Materialized {} datasets under {}".format(
            len(dataset_modes), output_root
        )
    )
    print("manifest\t{}".format(output_root / "all_datasets_locus_fasta_manifest.tsv"))
    print("dataset_manifest\t{}".format(output_root / "dataset_manifest.tsv"))


if __name__ == "__main__":
    main()
